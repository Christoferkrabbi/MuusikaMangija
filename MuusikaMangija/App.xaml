<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MuusikaMangija"
             xmlns:conv="clr-namespace:MuusikaMangija.Converters"
             x:Class="MuusikaMangija.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Styles (moved inside Application.Resources) -->
            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#FFFFFF, Dark=#121212}" />
            </Style>

            <!-- Global Style for Labels -->
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
            </Style>

            <!-- Global Style for Borders -->
            <Style TargetType="Border">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}" />
                <Setter Property="Stroke" Value="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" />
            </Style>

            <!-- Converters -->
            <conv:BoolToPlayPauseConverter x:Key="PlayPauseConverter" />

        </ResourceDictionary>
    </Application.Resources>    
</Application>
