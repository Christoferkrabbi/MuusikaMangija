<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MuusikaMangija.ViewModels"
             xmlns:models="clr-namespace:MuusikaMangija.Models"
             x:Class="MuusikaMangija.Views.HiddenSongsPage"
             x:Name="HiddenPage"
             Title="Hidden Songs">

    <VerticalStackLayout Padding="20" Spacing="10">
        <Label Text="Hidden songs (can unhide or delete permanently)" FontAttributes="Bold" />
        <CollectionView ItemsSource="{Binding HiddenSongs}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Song">
                    <Grid ColumnDefinitions="*, Auto, Auto" Padding="5">
                        <Label Text="{Binding Title}" Grid.Column="0" />
                        <Button Text="Unhide" Grid.Column="1" Command="{Binding Source={x:Reference HiddenPage}, Path=BindingContext.UnhideCommand}" CommandParameter="{Binding .}" />
                        <Button Text="Delete" Grid.Column="2" BackgroundColor="Red" TextColor="White" Command="{Binding Source={x:Reference HiddenPage}, Path=BindingContext.DeleteCommand}" CommandParameter="{Binding .}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
