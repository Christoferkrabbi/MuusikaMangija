<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MuusikaMangija.ViewModels"
             xmlns:models="clr-namespace:MuusikaMangija.Models"
             xmlns:helpers="clr-namespace:MuusikaMangija.Services"
             x:Name="RootPage"
             x:Class="MuusikaMangija.Views.AudioPlayerPage"
             Title="Muusikamängija">

    <Grid RowDefinitions="*, *, Auto" Padding="20" RowSpacing="15">

        <!-- 1. OSA: Kõik laulud (Lohistatavad elemendid) -->
        <Grid Grid.Row="0" RowDefinitions="Auto, Auto, *">

            <!-- Header Grid containing the Title and the Settings Button -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,5" VerticalOptions="Center">
                <!-- Title Header -->
                <Label Grid.Column="0" 
           Text="Kõik lood" 
           FontAttributes="Bold"
           VerticalOptions="Center" />

                <!-- ImageButton eliminates the text calculation glitch entirely -->
                <ImageButton Grid.Column="1"
                 Clicked="OnSettingsClicked"
                 WidthRequest="44"
                 HeightRequest="44"
                 VerticalOptions="Center"
                 BackgroundColor="Transparent">
                    <ImageButton.Source>
                        <FontImageSource Glyph="⚙" 
                             Size="24" 
                             Color="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    </ImageButton.Source>
                </ImageButton>
            </Grid>


            <!-- Action Control Buttons grouped horizontally -->
            <HorizontalStackLayout Grid.Row="1" Spacing="10" Margin="0,0,0,10">
                <Button Text="{Binding [ScanDevice], Source={x:Static helpers:LocalizationManager.Instance}}" 
                Clicked="OnScanClicked" 
                WidthRequest="120" />

                <Button Text="{Binding [Hidden], Source={x:Static helpers:LocalizationManager.Instance}}" Clicked="OnHiddenClicked" WidthRequest="90" />

                <Button Text="{Binding [ChooseFileManually], Source={x:Static helpers:LocalizationManager.Instance}}" 
                Command="{Binding PickFileCommand}">
                    <!-- Disable button cleanly while scanning using a DataTrigger -->
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </HorizontalStackLayout>
            
            <!-- Action Control Buttons grouped horizontally -->
            <HorizontalStackLayout Grid.Row="1" Spacing="10" Margin="0,0,0,10">
                <Button Text="{Binding [ScanDevice], Source={x:Static helpers:LocalizationManager.Instance}}" 
                        Clicked="OnScanClicked" 
                        WidthRequest="120" />

                <Button Text="{Binding [Hidden], Source={x:Static helpers:LocalizationManager.Instance}}" Clicked="OnHiddenClicked" WidthRequest="90" />

                <Button Text="{Binding [ChooseFileManually], Source={x:Static helpers:LocalizationManager.Instance}}" 
                        Command="{Binding PickFileCommand}">
                    <!-- Disable button cleanly while scanning using a DataTrigger -->
                    
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </HorizontalStackLayout>

            <!-- Songs Collection View -->
            <CollectionView Grid.Row="2" ItemsSource="{Binding AllSongs}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Song">
                        <Border Padding="10" Margin="0,3" StrokeShape="RoundRectangle 5">
                            <Border.GestureRecognizers>
                                <!-- Drag funktsioon -->
                                <DragGestureRecognizer CanDrag="True" DragStarting="OnDragStarting" />
                                <!-- Tap: animate & play via code-behind -->
                                <TapGestureRecognizer Tapped="OnSongTapped" NumberOfTapsRequired="1" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="🎵" VerticalOptions="Center" />

                                <VerticalStackLayout Grid.Column="1" HorizontalOptions="StartAndExpand">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="15" LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding Artist}" FontSize="12" TextColor="Gray"/>
                                </VerticalStackLayout>

                                <!-- Menu button aligned to the right -->
                                <Button Grid.Column="2"
                                        Text="⋮"
                                        Clicked="OnMenuClicked"
                                        CommandParameter="{Binding .}"
                                        WidthRequest="44"
                                        HeightRequest="40"
                                        FontSize="20"
                                        HorizontalOptions="End"
                                        BackgroundColor="Transparent"
                                        TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- 2. OSA: Mängujärjekord -->
        <Border Grid.Row="1" StrokeThickness="2" StrokeDashArray="4,2" StrokeShape="RoundRectangle 10">
            <Border.GestureRecognizers>
                <DropGestureRecognizer AllowDrop="True" Drop="OnDrop" />
            </Border.GestureRecognizers>

            <Grid RowDefinitions="Auto, *">
                <Label Grid.Row="0" Text="Mängujärjekord (Lohista lood siia)" HorizontalOptions="Center" Margin="10" TextColor="DimGray"/>
                <CollectionView Grid.Row="1" ItemsSource="{Binding PlaybackQueue}" Margin="10">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Song">
                        <Border Padding="8" Margin="2">

                                <Border.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStarting="OnQueueDragStarting" />
                                    <DropGestureRecognizer AllowDrop="True" Drop="OnQueueDrop" />
                                    <!-- Tap to play this queue item -->
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.PlaySongCommand}" CommandParameter="{Binding .}" NumberOfTapsRequired="1" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                    <Label Grid.Column="0" Text="☰" FontSize="20" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding Title}" LineBreakMode="TailTruncation" MaxLines="1" VerticalOptions="Center" />
                                    <!-- Use an icon button to avoid truncation on small screens -->
                                    <Button Grid.Column="2" Text="✖" Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.RemoveFromQueueCommand}" CommandParameter="{Binding .}" WidthRequest="40" HeightRequest="36" FontSize="18" BackgroundColor="Transparent" />
                                </Grid>

                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <!-- 3. OSA: Alumine juhtpaneel-->
        <Border Grid.Row="2" Padding="12" StrokeShape="RoundRectangle 15" BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#202020}">
            <VerticalStackLayout Spacing="8" HorizontalOptions="Fill" VerticalOptions="Center">
                <!-- Current song (bold) centered above controls -->
                <Label Text="{Binding CurrentSong.Title, TargetNullValue='Pole valitud'}" FontAttributes="Bold" HorizontalOptions="Center" LineBreakMode="TailTruncation" />
                <Label Text="{Binding CurrentSong.Artist, TargetNullValue='-'}" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />

                <!-- Controls centered -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Button Text="{Binding [SongPrevious], Source={x:Static helpers:LocalizationManager.Instance}}" Command="{Binding PlayPreviousCommand}" WidthRequest="56" HeightRequest="40" />
                    <Button Text="{Binding IsPlaying, Converter={StaticResource PlayPauseConverter}}" 
                            Command="{Binding PlayPauseCommand}"
                            WidthRequest="80"
                            HeightRequest="45"/>

                    <Button Text="{Binding [SongNext], Source={x:Static helpers:LocalizationManager.Instance}}" Command="{Binding PlayNextCommand}" WidthRequest="56" HeightRequest="40" />
                    <Button Text="{Binding [Button_ClearQueue], Source={x:Static helpers:LocalizationManager.Instance}}" Command="{Binding ClearQueueCommand}" WidthRequest="70" HeightRequest="40" />
                </HorizontalStackLayout>

                <!-- Next song preview under controls -->
                <Label Text="{Binding NextSong.Title, StringFormat='Next song: {0}', TargetNullValue='Next song: -'}" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />

                <!-- Status message -->
                <Label Text="{Binding StatusMessage}" TextColor="DimGray" FontSize="12" FontAttributes="Italic" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Border>

        <!-- Global Loading Overlay Panel -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              BackgroundColor="#CC000000"
              IsVisible="{Binding IsBusy}"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" HeightRequest="50" WidthRequest="50" />
                <Label Text="{Binding StatusMessage}" TextColor="White" FontSize="16" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
